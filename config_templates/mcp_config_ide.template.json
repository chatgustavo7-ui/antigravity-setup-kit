{
  "mcpServers": {
    "arize-tracing-assistant": {
      "command": "__PATH_TO_NPX_CMD__",
      "args": [
        "-y",
        "@arize/tracing-assistant-mcp"
      ],
      "env": {
        "ARIZE_SPACE_ID": "__YOUR_ARIZE_SPACE_ID__",
        "ARIZE_API_KEY": "__YOUR_ARIZE_API_KEY__"
      }
    },
    "bigquery": {
      "command": "__PATH_TO_NPX_CMD__",
      "args": [
        "-y",
        "@google-cloud/mcp-server-bigquery"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "__YOUR_GCP_CREDENTIALS_JSON_PATH__",
        "GCP_PROJECT_ID": "__YOUR_GCP_PROJECT_ID__"
      }
    },
    "claude-mem": {
      "command": "__PATH_TO_NODE_EXE__",
      "args": [
        "__PATH_TO_CLAUDE_MEM_SERVER_JS__"
      ],
      "env": {
        "MEM_DATABASE_URL": "__YOUR_MEM_DATABASE_URL__"
      }
    },
    "clickhouse": {
      "command": "__PATH_TO_NPX_CMD__",
      "args": [
        "-y",
        "@clickhouse/mcp-server"
      ],
      "env": {
        "CLICKHOUSE_HOST": "__YOUR_CLICKHOUSE_HOST__",
        "CLICKHOUSE_PORT": "__YOUR_CLICKHOUSE_PORT__",
        "CLICKHOUSE_USER": "__YOUR_CLICKHOUSE_USER__",
        "CLICKHOUSE_PASSWORD": "__YOUR_CLICKHOUSE_PASSWORD__",
        "CLICKHOUSE_DATABASE": "__YOUR_CLICKHOUSE_DATABASE__"
      }
    },
    "cloudrun": {
      "command": "__PATH_TO_NPX_CMD__",
      "args": [
        "-y",
        "@google-cloud/mcp-server-cloudrun"
      ],
      "env": {
        "GOOGLE_APPLICATION_CREDENTIALS": "__YOUR_GCP_CREDENTIALS_JSON_PATH__",
        "GCP_PROJECT_ID": "__YOUR_GCP_PROJECT_ID__"
      }
    },
    "datacloud_bigquery_remote": {
      "command": "__PATH_TO_PYTHON_EXE__",
      "args": [
        "-m",
        "mcp_datacloud_bigquery_remote"
      ],
      "env": {
        "DATACLOUD_API_KEY": "__YOUR_DATACLOUD_API_KEY__",
        "DATACLOUD_ENDPOINT": "__YOUR_DATACLOUD_ENDPOINT__"
      }
    },
    "datacloud_cloud-sql_remote": {
      "command": "__PATH_TO_PYTHON_EXE__",
      "args": [
        "-m",
        "mcp_datacloud_cloud_sql_remote"
